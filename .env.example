# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel Blob token for persistent session storage
# In Vercel, create a Blob store and connect it to the project
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# ElevenLabs Text-to-Speech (high-quality story/question narration)
# Get your key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_selected_voice_id_here
# Optional override voices (falls back to ELEVENLABS_VOICE_ID when omitted)
ELEVENLABS_VOICE_ID_STORY_A=optional_voice_id_for_story_a
ELEVENLABS_VOICE_ID_STORY_B=optional_feminine_voice_id_for_story_b
ELEVENLABS_VOICE_ID_QUESTION=optional_voice_id_for_questions
# Optional: defaults to eleven_multilingual_v2 if omitted
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Admin dashboard password (change this to something strong)
ADMIN_PASSWORD=uofn-admin-2024

# Secret for session tokens (generate a random string, at least 32 chars)
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars
