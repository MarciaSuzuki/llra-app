# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Admin dashboard password (change this to something strong)
ADMIN_PASSWORD=uofn-admin-2024

# Secret for session tokens (generate a random string, at least 32 chars)
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars
